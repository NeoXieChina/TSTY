}

.toggle-active .toggle-thumb {
	transform: translateX(48rpx);
}

// 退出登录容器
.logout-container {
	padding: 32rpx 0;
}

// 退出登录按钮
.logout-button {
	width: 100%;
	padding: 32rpx;
	background-color: #cc0000;
	border-radius: 28rpx;
	display: flex;
	flex-direction: row;
