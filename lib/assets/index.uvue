						<view class="setting-label">
							<view class="setting-icon icon-purple">
								<cl-icon name="ri-user-3-fill" :size="32" color="#ffffff"></cl-icon>
							</view>
							<text class="setting-text">卡通人物选择</text>
						</view>
						<cl-icon name="arrow-right-s-line" :size="32" color="#cc0000"></cl-icon>
					</view>
				</view>

				<!-- 隐私与安全 -->
				<view class="section-title">隐私与安全</view>
				<view class="settings-section">
					<view class="setting-item" @tap="showTips('隐私设置')">
						<view class="setting-label">
							<view class="setting-icon icon-red">
								<cl-icon name="ri-shield-keyhole-fill" :size="32" color="#ffffff"></cl-icon>
							</view>
							<text class="setting-text">隐私设置</text>
						</view>
						<cl-icon name="arrow-right-s-line" :size="32" color="#cc0000"></cl-icon>
					</view>

