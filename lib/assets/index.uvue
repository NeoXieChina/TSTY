		<cl-popup v-model="showChangePassword" direction="center" :size="620" :show-header="false">
			<view class="change-pwd-modal">
				<text class="change-pwd-title">修改密码</text>
				<cl-form
					ref="changePwdFormRef"
					v-model="changePwdForm"
					:rules="changePwdRules"
					label-position="top"
					:show-asterisk="false"
					class="change-pwd-form"
				>
					<cl-form-item label="原密码" prop="oldPassword" required>
						<cl-input v-model="changePwdForm.oldPassword" type="password" placeholder="请输入原密码" :border="true"></cl-input>
					</cl-form-item>
					<cl-form-item label="新密码" prop="newPassword" required>
						<cl-input v-model="changePwdForm.newPassword" type="password" placeholder="请输入新密码(6-20位)" :border="true"></cl-input>
					</cl-form-item>
					<cl-form-item label="确认新密码" prop="confirmPassword" required>
						<cl-input v-model="changePwdForm.confirmPassword" type="password" placeholder="请再次输入新密码" :border="true"></cl-input>
					</cl-form-item>
				</cl-form>

				<view class="change-pwd-actions">
					<cl-button :disabled="changePwdLoading" :pt="{ className: 'change-pwd-btn' }" @tap="closeChangePassword">取消</cl-button>
					<cl-button type="primary" :loading="changePwdLoading" :pt="{ className: 'change-pwd-btn' }" @tap="submitChangePassword">确认</cl-button>
				</view>
			</view>
		</cl-popup>
	</cl-page>
</template>

<script setup lang="ts">
import { ref, type Ref } from "vue";
import { router, useStore, request } from "@/cool";
import { useUi, useForm, type ClFormRule } from "@/uni_modules/cool-ui";
import YiStripe from "@/components/yi-stripe.uvue";
import { encryptPassword } from "@/cool/utils/crypto";

const ui = useUi();
const { user } = useStore();

// 音效开关状态
const soundEnabled = ref<boolean>(true);

// 退出登录加载状态
const logoutLoading = ref<boolean>(false);

type ChangePwdForm = {
	oldPassword: string;
	newPassword: string;
	confirmPassword: string;
};

const showChangePassword = ref<boolean>(false);
const changePwdLoading = ref<boolean>(false);

const changePwdForm = ref<ChangePwdForm>({
	oldPassword: "",
	newPassword: "",
	confirmPassword: ""
}) as Ref<ChangePwdForm>;

const changePwdRules = new Map<string, ClFormRule[]>([
	["oldPassword", [{ required: true, message: "请输入原密码" }]],
	["newPassword", [{ required: true, message: "请输入新密码" }]],
	["confirmPassword", [{ required: true, message: "请确认新密码" }]]
]);

const { formRef: changePwdFormRef, validate: validateChangePwdForm, clearValidate: clearChangePwdValidate } = useForm();

// 返回上一页
function goBack() {
	router.back();
}

function onSoundChange(val: boolean) {
	ui.showToast({
		message: val ? "音效已开启" : "音效已关闭"
	});
}

// 显示提示
function showTips(title : string) {
	ui.showToast({
		message: `${title}功能开发中...`
	});
}

function safeClearChangePwdValidate(): void {
	if (changePwdFormRef.value == null) return;
	changePwdFormRef.value.clearValidate();
}

function openChangePassword() {
	changePwdForm.value.oldPassword = "";
	changePwdForm.value.newPassword = "";
	changePwdForm.value.confirmPassword = "";
	showChangePassword.value = true;
	setTimeout(() => {
		safeClearChangePwdValidate();
	}, 0);
}

function closeChangePassword() {
	showChangePassword.value = false;
	safeClearChangePwdValidate();
}

async function doChangePassword(oldPwd: string, newPwd: string, confirmPwd: string): Promise<void> {
	if (changePwdLoading.value) return;
	changePwdLoading.value = true;
	try {
		await request<UTSJSONObject>({
			url: "/api/v1/auth/change-password",
			method: "POST",
			data: {
				oldPassword: encryptPassword(oldPwd),
				newPassword: encryptPassword(newPwd),
				confirmPassword: encryptPassword(confirmPwd)
			}
		});
		ui.showToast({ message: "密码修改成功" });
		closeChangePassword();
	} catch (err: any) {
		let msg = "修改密码失败";
		const e = err as UTSJSONObject;
		const m = e != null ? (e["message"] as string | null) : null;
		if (m != null && m != "") {
			msg = m;
		}
		ui.showToast({ message: msg });
	} finally {
		changePwdLoading.value = false;
	}
}

function submitChangePassword(): void {
	if (changePwdLoading.value) return;

	validateChangePwdForm(function (valid, _errors) {
		if (valid == false) {
			return;
		}

		const oldPwd = changePwdForm.value.oldPassword.trim();
		const newPwd = changePwdForm.value.newPassword.trim();
		const confirmPwd = changePwdForm.value.confirmPassword.trim();

		if (newPwd.length < 6 || newPwd.length > 20) {
			ui.showToast({ message: "密码长度应为6-20位" });
			return;
		}
		if (confirmPwd != newPwd) {
			ui.showToast({ message: "两次输入的密码不一致" });
			return;
		}

		doChangePassword(oldPwd, newPwd, confirmPwd);
	});
}

// 清除缓存
function clearCache() {
	ui.showConfirm({
		title: "清除缓存",
		message: "确定要清除缓存吗？",
		callback(action) {
			if (action == "confirm") {
				ui.showToast({
					message: "缓存已清除"
				});
			}
		}
	});
}

// 退出登录
function toLogout() {
	ui.showConfirm({
		title: "提示",
		message: "确定退出登录吗？",
		callback(action) {
			if (action == "confirm") {
				logoutLoading.value = true;

				// 模拟退出操作
				setTimeout(() => {
					logoutLoading.value = false;
					user.logout();
				}, 1000);
			}
		}
	});
}
</script>

